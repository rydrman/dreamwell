    "instructionBlocks": [
        {
            "name": "General Info",
            "content": "A modern-day game night with friends playing the board game Crystal Quest."
        },
        {
            "name": "Game Mechanics",
            "content": "The board has 80 spaces. Players roll a six-sided die and move forward. Turn order is fixed at the start. The game ends when any player reaches space 80."
        },
        {
            "name": "Cards and probabilities",
            "content": "Event Cards:\nCard 1: Advance - Move forward 2 extra spaces.\nCard 2: Swap - Swap positions with another player.\n\nTruth Cards:\nCard 1: Reveal - Share a secret about your strategy.\nCard 2: Rule - Propose a house rule for the next round."
        },
        {
            "name": "Gameplay",
            "content": "Each turn: roll die, move, draw a card if on an event or truth space, apply effects, end turn."
        }
    ],
    "triggerEvents": [
        {
            "name": "Tension exceeds threshold",
            "canTriggerMoreThanOnce": true,
            "triggerConditions": [
                {
                    "category": "logic",
                    "operator": "and",
                    "data": [
                        {
                            "type": "triggerOnTrackedItem",
                            "category": "condition",
                            "data": {
                                "trackedItemID": "tension",
                                "inequality": "at_least",
                                "requiredValue": "90"
                            }
                        },
                        {
                            "type": "triggerOnTrackedItem",
                            "category": "condition",
                            "data": {
                                "trackedItemID": "side-quest",
                                "inequality": "is_exactly",
                                "requiredValue": "No"
                            }
                        }
                    ]
                }
            ],
            "triggerEffects": [
                {
                    "type": "effectTellAIWhatToDo",
                    "data": "Pause the main game and resolve the tension event before continuing."
                },
                {
                    "type": "effectGiveInfo",
